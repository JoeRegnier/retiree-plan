{
  "name": "@retiree-plan/desktop",
  "version": "0.1.0",
  "description": "Retiree Plan – Desktop Application",
  "author": {
    "name": "Retiree Plan",
    "email": "maintainer@retireeplan.app"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/fox-den/retireeplan.git"
  },
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && electron .",
    "postinstall": "electron-builder install-app-deps",
    "package": "bash scripts/build-desktop.sh",
    "package:dir": "npm run build && electron-builder --dir"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.3",
    "electron": "35.7.5",
    "electron-builder": "^26.8.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  }
}
