generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  households           Household[]
  ynabConnection       YnabConnection?
  aiMessages           AiMessage[]
  brokerageConnections BrokerageConnection[]
}

model Household {
  id               String            @id @default(cuid())
  name             String
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  members          HouseholdMember[]
  accounts         Account[]
  realEstateProperties RealEstate[]
  goals            Goal[]
  scenarios        Scenario[]
  expenses              Expense[]
  milestoneEvents       MilestoneEvent[]
  ynabCategoryMappings  YnabCategoryMapping[]
  decisionRecords       DecisionRecord[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model HouseholdMember {
  id            String         @id @default(cuid())
  name          String
  dateOfBirth   DateTime
  province      String
  retirementAge Int            @default(65)
  /// User-entered current RRSP contribution room (from CRA Notice of Assessment)
  rrspContributionRoom Float?
  /// User-entered current TFSA contribution room
  tfsaContributionRoom Float?
  /// Prior-year earned income (used for RRSP room calculation)
  priorYearIncome      Float?
  /// User-entered expected CPP monthly benefit at age 65
  cppExpectedBenefit   Float?
  householdId   String
  household     Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  incomeSources IncomeSource[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model IncomeSource {
  id               String          @id @default(cuid())
  name             String
  type             String
  annualAmount     Float
  startAge         Int?
  endAge           Int?
  indexToInflation Boolean         @default(true)
  memberId         String
  member           HouseholdMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Expense {
  id               String    @id @default(cuid())
  name             String
  category         String
  annualAmount     Float
  startAge         Int?
  endAge           Int?
  indexToInflation Boolean   @default(true)
  householdId      String
  household        Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([householdId, name])
}

model Account {
  id                 String    @id @default(cuid())
  name               String
  type               String
  balance            Float     @default(0)
  currency           String    @default("CAD")
  annualContribution  Float   @default(0)
  /// User-supplied annual return / interest rate for this specific account.
  /// When set, the projection engine uses this rate instead of the scenario's
  /// base expected return rate. Null means "use the scenario default".
  estimatedReturnRate Float?
  householdId         String
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  // Optional link to a YNAB account — balance synced automatically
  ynabAccountId        String?
  ynabAccountName      String?
  // Optional link to a brokerage account (Questrade / Wealthsimple / TD)
  brokerageAccountId   String?
  brokerageProvider    String?   // 'QUESTRADE' | 'WEALTHSIMPLE' | 'TD'
  brokerageAccountName String?
  equityPercent        Float?
  fixedIncomePercent   Float?
  alternativesPercent  Float?
  cashPercent          Float?
  /// Adjusted cost base for non-registered accounts — used for capital gains tracking.
  costBasis            Float?
  /// True when this RRSP was funded by a spouse's contributions (spousal RRSP).
  isSpousalRrsp        Boolean   @default(false)
  /// HouseholdMember id of the person who made the contributions (spousal RRSP contributor).
  contributorMemberId  String?
  /// HouseholdMember id of the plan annuitant (owner).
  annuitantMemberId    String?
  /// Calendar year of the most recent spousal contribution — drives attribution rule check.
  lastContributionYear Int?
  /// Historical ownership/tax attribution records used for member-level reporting.
  taxAttributionHistory AccountTaxAttributionHistory[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model AccountTaxAttributionHistory {
  id                String   @id @default(cuid())
  accountId         String
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  /// Calendar year from which this attribution applies.
  effectiveYear     Int
  /// 'JOINT_UNSPECIFIED' | 'SINGLE_MEMBER' | 'JOINT_PERCENTAGE'
  mode              String   @default("JOINT_UNSPECIFIED")
  /// Member id receiving full attribution for SINGLE_MEMBER mode.
  primaryMemberId   String?
  /// Optional second member id for JOINT_PERCENTAGE mode.
  secondaryMemberId String?
  /// 0..1 fraction for primary member in JOINT_PERCENTAGE mode.
  primaryPercentage Float?
  /// 0..1 fraction for secondary member in JOINT_PERCENTAGE mode.
  secondaryPercentage Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([accountId, effectiveYear])
}

model RealEstate {
  id                 String    @id @default(cuid())
  name               String
  propertyType       String    // 'PRIMARY_RESIDENCE' | 'RENTAL' | 'VACATION'
  currentValue       Float
  purchasePrice      Float     @default(0)
  annualAppreciation Float     @default(0.03)
  grossRentalIncome  Float?
  rentalExpenses     Float?
  sellAtAge          Int?
  netProceedsPercent Float     @default(0.95)
  householdId        String
  household          Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Scenario {
  id          String    @id @default(cuid())
  name        String
  description String?
  parameters  String
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model HistoricalReturn {
  id         String    @id @default(cuid())
  year       Int
  asset      String
  returnRate Float
  /// 'SEED' | 'YAHOO' | 'BOC'
  source     String    @default("SEED")
  /// Ticker symbol for Yahoo-fetched series (e.g. 'XIC.TO'); empty for seeded series
  ticker     String    @default("")
  /// When this record was last fetched from an external source
  fetchedAt  DateTime?

  @@unique([year, asset])
}

model MilestoneEvent {
  id          String    @id @default(cuid())
  name        String
  description String?
  age         Int
  amount      Float
  type        String    // 'income' | 'expense' | 'lump_sum_in' | 'lump_sum_out'
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Goal {
  id           String    @id @default(cuid())
  name         String
  description  String?
  targetAmount Float
  targetAge    Int?
  priority     String    @default("essential")   // 'essential' | 'discretionary'
  category     String    @default("retirement")  // 'retirement' | 'legacy' | 'purchase' | 'lifestyle'
  householdId  String
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── Phase 5: YNAB Integration ───────────────────────────────────────────────

model YnabConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String?
  budgetId     String?
  budgetName   String?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model YnabCategoryMapping {
  id               String    @id @default(cuid())
  ynabCategoryId   String
  ynabCategoryName String
  localCategory    String    // maps to Expense.category
  /// Age at which this expense begins (inclusive). Null = no lower bound.
  startAge         Int?
  /// Age at which this expense ends (inclusive). Null = no upper bound.
  endAge           Int?
  householdId      String
  household        Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([householdId, ynabCategoryId])
}

// ─── Phase 6: Brokerage Integrations ────────────────────────────────────────

/// Stores OAuth2 / PAT credentials for Canadian brokerage integrations.
/// provider is one of: 'QUESTRADE' | 'WEALTHSIMPLE' | 'TD'
model BrokerageConnection {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String    // 'QUESTRADE' | 'WEALTHSIMPLE' | 'TD'
  /// Encrypted access token (Wealthsimple PAT; unused for Questrade after first exchange)
  accessToken  String?
  /// Encrypted refresh token (Questrade; also used as PAT for Wealthsimple initial storage)
  refreshToken String?
  /// Questrade returns a per-user API server URL on each token exchange
  apiServer    String?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
}

// ─── Decision Journal ────────────────────────────────────────────────────────

/// A recorded financial decision following the ADR (Architectural Decision Record) pattern.
/// status: 'PROPOSED' | 'DECIDED' | 'SUPERSEDED' | 'DEPRECATED' | 'REJECTED'
/// category: 'WITHDRAWAL_STRATEGY' | 'ASSET_ALLOCATION' | 'TAX_PLANNING' |
///           'CPP_OAS_TIMING' | 'HOUSING' | 'ESTATE' | 'INCOME' | 'INSURANCE' | 'GENERAL'
model DecisionRecord {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  title        String
  status       String    @default("PROPOSED")
  context      String
  decision     String?
  rationale    String?
  /// JSON: AlternativeOption[] { title, description, whyRejected? }
  alternatives String?
  consequences String?

  category String  @default("GENERAL")
  /// JSON: string[]
  tags     String?

  decisionDate DateTime?
  reviewDate   DateTime?

  // Supersession chain — one record supersedes at most one other record
  supersededById String?
  supersededBy   DecisionRecord?  @relation("Supersession", fields: [supersededById], references: [id])
  supersedes     DecisionRecord[] @relation("Supersession")

  /// JSON: string[] — cuid IDs of linked Scenario records
  linkedScenarioIds String?
  /// JSON: string[] — cuid IDs of linked Goal records
  linkedGoalIds     String?

  // Mind-map edges — implicit M2M self-relation
  relatedTo   DecisionRecord[] @relation("DecisionRelations")
  relatedFrom DecisionRecord[] @relation("DecisionRelations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Phase 5: AI Chat ────────────────────────────────────────────────────────

model AiMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // 'user' | 'assistant' | 'system'
  content   String
  createdAt DateTime @default(now())
}
